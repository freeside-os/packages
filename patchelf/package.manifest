[package]
name = "patchelf"
version = "0.18.0"
description = "A utility for modifying ELF binaries' dynamic linker and rpath"
dependencies = ["musl"]
group = "builder"

[[sources]]
url = "https://github.com/NixOS/patchelf/releases/download/0.18.0/patchelf-0.18.0.tar.gz"
checksum = { algorithm = "sha256", value = "64de10e4c6b8b8379db7e87f58030f336ea747c0515f381132e810dbf84a86e7" }

[build]

[build.environment]
CONFIGURE_ARGS = "--prefix=/usr"
dependencies = ["musl"]
