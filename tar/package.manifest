[package]
name = "tar"
version = "1.35"
description = "GNU tape archiver"
dependencies = ["musl"]
group = "base"

[[sources]]
url = "https://ftp.gnu.org/gnu/tar/tar-1.35.tar.xz"
checksum = { algorithm = "sha256", value = "4d62ff37342ec7aed748535323930c7cf94acf71c3591882b26a7ea50f3edc16" }

[build]
dependencies = ["musl"]

[build.environment]
FORCE_UNSAFE_CONFIGURE = "1"
