[package]
name = "libexpat"
version = "2.6.2"
description = "Stream-oriented XML parser library"
dependencies = ["musl"]
group = "system"

[[sources]]
url = "https://github.com/libexpat/libexpat/releases/download/R_2_6_2/expat-2.6.2.tar.xz"
checksum = { algorithm = "sha256", value = "ee14b4c5d8908b1bec37ad937607eab183d4d9806a08adee472c3c3121d27364" }

[build]

[build.environment]
CONFIGURE_ARGS = "--prefix=/usr --enable-shared --enable-static"
dependencies = ["musl"]
