[package]
name = "xz"
version = "5.6.2"
description = "LZMA compression utilities"
dependencies = ["musl"]
group = "builder"

[[sources]]
url = "https://github.com/tukaani-project/xz/releases/download/v5.6.2/xz-5.6.2.tar.gz"
checksum = { algorithm = "sha256", value = "8bfd20c0e1d86f0402f2497cfa71c6ab62d4cd35fd704276e3140bfb71414519" }

[build]

[build.environment]
CONFIGURE_ARGS = "--prefix=/usr --disable-static"
dependencies = ["musl"]
