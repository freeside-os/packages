[package]
name = "nmap"
version = "7.99"
description = "Nmap is a utility for network exploration and security auditing."
group = "server"
dependencies = ["musl", "openssl", "zlib"]

[build]
dependencies = ["musl", "openssl", "zlib", "linux-headers"]

