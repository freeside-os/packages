[package]
name = "gawk"
version = "5.4.0"
description = "GNU awk text processing utility"
dependencies = ["musl"]
group = "base"

[[sources]]
url = "https://ftp.gnu.org/gnu/gawk/gawk-5.4.0.tar.xz"
checksum = { algorithm = "sha256", value = "3dd430f0cd3b4428c6c3f6afc021b9cd3c1f8c93f7a688dc268ca428a90b4ac1" }

[build]

[build.environment]
CONFIGURE_ARGS = "--prefix=/usr --disable-nls"
dependencies = ["musl"]
