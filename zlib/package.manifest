[package]
name = "zlib"
version = "1.3.1"
description = "A free, general-purpose, lossless data-compression library"
dependencies = ["musl"]
group = "base"

[[sources]]
url = "https://zlib.net/fossils/zlib-1.3.1.tar.gz"
checksum = { algorithm = "sha256", value = "9a93b2b7dfdac77ceba5a558a580e74667dd6fede4585b91eefb60f03b72df23" }

[build]

[build.environment]
CONFIGURE_ARGS = "--prefix=/usr --shared"
dependencies = ["musl"]
