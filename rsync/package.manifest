[package]
name = "rsync"
version = "3.3.0"
description = "A fast, versatile, remote (and local) file-copying tool"
dependencies = ["musl", "zlib"]
group = "builder"

[[sources]]
url = "https://download.samba.org/pub/rsync/src/rsync-3.3.0.tar.gz"
checksum = { algorithm = "sha256", value = "7399e9a6708c32d678a72a63219e96f23be0be2336e50fd1348498d07041df90" }

[build]
dependencies = ["musl", "zlib", "make"]
