[package]
name = "sed"
version = "4.10"
description = "GNU stream editor"
dependencies = ["musl"]
group = "base"

[[sources]]
url = "https://ftp.gnu.org/gnu/sed/sed-4.10.tar.xz"
checksum = { algorithm = "sha256", value = "b8e72182b2ec96a3574e2998c47b7aaa64cc20ce000d8e9ac313cc07cecf28c7" }

[build]

[build.environment]
CONFIGURE_ARGS = "--prefix=/usr --disable-nls"
dependencies = ["musl"]
