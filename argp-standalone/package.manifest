[package]
name = "argp-standalone"
version = "1.3"
description = "Standalone argp library for systems lacking it in libc (like musl)"
group = "linux"
dependencies = ["musl"]

[build]
dependencies = ["llvm", "make", "musl"]

[[sources]]
url = "https://www.lysator.liu.se/~nisse/misc/argp-standalone-1.3.tar.gz"
