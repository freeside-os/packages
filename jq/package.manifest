[package]
name = "jq"
version = "1.8.2"
description = "Lightweight and flexible command-line JSON processor"
group = "server"

[[sources]]
url = "https://github.com/jqlang/jq/releases/download/jq-1.8.2/jq-1.8.2.tar.gz"
checksum = { algorithm = "sha256", value = "71b8d6e8f5fe81f6c6d0d110e3892251f6ce76ed095abd315e26e6e1193af3af" }

[build]

[build.environment]
CONFIGURE_ARGS = "--prefix=/usr --disable-static"
