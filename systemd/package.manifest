[package]
name = "systemd"
version = "255"
description = "System and Service Manager"
dependencies = ["musl", "util-linux", "libcap", "musl-utils"]
group = "system"

[[sources]]
url = "https://github.com/systemd/systemd/archive/refs/tags/v255.tar.gz"
