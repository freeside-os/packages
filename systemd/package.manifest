[build]
dependencies = [
    "musl",
    "util-linux",
    "libcap",
    "musl-utils",
    "meson",
    "ninja",
    "pkgconf",
    "gperf",
    "python3",
    "python-markupsafe",
    "python-jinja2",
    "llvm"
]
