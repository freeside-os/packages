[package]
name = "libarchive"
version = "3.7.4"
description = "Multi-format archive and compression library"
dependencies = ["musl", "zlib"]
group = "system"

[[sources]]
url = "https://github.com/libarchive/libarchive/releases/download/v3.7.4/libarchive-3.7.4.tar.gz"
checksum = { algorithm = "sha256", value = "7875d49596286055b52439ed42f044bd8ad426aa4cc5aabd96bfe7abb971d5e8" }

[build]

[build.environment]
CONFIGURE_ARGS = "--prefix=/usr --disable-static"
dependencies = ["musl", "zlib"]
